# ════════════════════════════════════════════════════════════════
#  AI PLATFORM — Environment Variables
#  Copy this file: cp .env.example .env
#  Then run:       node scripts/gen-secrets.js
#  to auto-fill all secret keys
# ════════════════════════════════════════════════════════════════

# ── LibreChat Core ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# ── LibreChat Security (run: node scripts/gen-secrets.js) ────────
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX
CREDS_KEY=REPLACE_WITH_64_CHAR_HEX
CREDS_IV=REPLACE_WITH_32_CHAR_HEX
MEILI_MASTER_KEY=REPLACE_WITH_40_CHAR_HEX

# ── AI Provider API Keys (add the ones you have) ─────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_KEY=AIza...
# AZURE_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=

# ── LibreChat Endpoints (which providers show in UI) ─────────────
ENDPOINTS=openAI,agents,anthropic,google,custom

# ── Databases ───────────────────────────────────────────────────
MONGO_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_USER=lcuser
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=librechat
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# MongoDB connection URI (used by LibreChat)
MONGO_URI=mongodb://admin:${MONGO_PASSWORD}@mongodb:27017/LibreChat?authSource=admin

# PostgreSQL connection URL (used by RAG API)
POSTGRES_URL=postgresql://lcuser:${POSTGRES_PASSWORD}@vectordb:5432/librechat

# ── RAG / Embeddings ─────────────────────────────────────────────
RAG_API_URL=http://rag_api:8000
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
# To use free local embeddings (requires Ollama):
# EMBEDDINGS_PROVIDER=ollama
# EMBEDDINGS_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://ollama:11434

# ── Search ───────────────────────────────────────────────────────
SEARCH=true
MEILI_HOST=http://meilisearch:7700

# ── Registration ─────────────────────────────────────────────────
ALLOW_REGISTRATION=true
# Set to false after creating your admin account!

# ── OAuth (optional) ─────────────────────────────────────────────
ALLOW_SOCIAL_LOGIN=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=/oauth/google/callback
# GOOGLE_OAUTH_DOMAIN=yourcompany.com

# ── Rate Limiting ────────────────────────────────────────────────
BAN_VIOLATIONS=true
BAN_DURATION=7200000
LOGIN_MAX=7
LOGIN_WINDOW=5

# ── API Gateway ──────────────────────────────────────────────────
GATEWAY_PORT=4000
GATEWAY_JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
LIBRECHAT_ADMIN_EMAIL=admin@example.com
LIBRECHAT_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD

# ── MCP Servers ──────────────────────────────────────────────────
MCP_SHARED_SECRET=REPLACE_WITH_48_CHAR_HEX

# For tools-server
BRAVE_API_KEY=BSA_your_brave_search_api_key
OPENWEATHER_KEY=your_openweather_api_key

# For db-server (your analytics database)
ANALYTICS_DB_URL=postgresql://user:pass@host:5432/analytics

# ── React App ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_APP_TITLE=AI Platform

# ── File Storage ─────────────────────────────────────────────────
# Default: local disk. For production, switch to S3:
# FILEUPLOAD_S3_BUCKET=your-bucket
# FILEUPLOAD_S3_REGION=ap-south-1
# FILEUPLOAD_S3_ACCESS_KEY=
# FILEUPLOAD_S3_SECRET_KEY=
# FILE_UPLOAD_STORAGE=s3

# ── App Branding ─────────────────────────────────────────────────
APP_TITLE=AI Platform
NO_INDEX=true
